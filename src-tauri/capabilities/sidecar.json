{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "sidecar",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "bin/ffmpeg", "sidecar": true, "args": true },
        { "name": "bin/ffprobe", "sidecar": true, "args": true }
      ]
    }
  ]
}
